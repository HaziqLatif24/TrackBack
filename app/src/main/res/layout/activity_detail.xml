<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Header Banner Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#311B92"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingVertical="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Items Information"
                android:textSize="24sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="#FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View listing specifications, location, and owner details"
                android:textSize="13sp"
                android:fontFamily="sans-serif"
                android:textColor="#D1C4E9"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Main Body Content Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Title Header Heading -->
            <TextView
                android:id="@+id/tvDetailTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Item Title Header"
                android:textSize="24sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="#202124"
                android:layout_marginBottom="6dp"/>

            <!-- Item Description Text -->
            <TextView
                android:id="@+id/tvDetailDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Item contextual description content details populate here dynamically."
                android:textSize="15sp"
                android:fontFamily="sans-serif"
                android:textColor="#5F6368"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="20dp"/>

            <!-- Relocated Image Container Box (Now underneath name and description) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvDetailPhotoContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="24dp">
                <ImageView
                    android:id="@+id/ivDetailPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:background="#F1F3F4" />
            </androidx.cardview.widget.CardView>

            <!-- Pinned Map Component Section -->
            <LinearLayout
                android:id="@+id/layoutDetailMapSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E8EAED"
                    android:layout_marginBottom="20dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Discovered Coordinates Area"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="14sp"
                    android:textColor="#311B92"
                    android:layout_marginBottom="10dp"/>
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="24dp">
                    <fragment
                        android:id="@+id/detailMap"
                        android:name="com.google.android.gms.maps.SupportMapFragment"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E8EAED"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan QR to Claim / Contact Owner"
                android:fontFamily="sans-serif-medium"
                android:textSize="14sp"
                android:textColor="#311B92"
                android:layout_marginBottom="14dp"/>

            <!-- WhatsApp QR Framing Box Layout -->
            <androidx.cardview.widget.CardView
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center"
                app:cardCornerRadius="14dp"
                app:cardElevation="1dp"
                android:layout_marginBottom="28dp">
                <ImageView
                    android:id="@+id/ivWhatsAppQR"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="10dp"
                    android:scaleType="fitCenter"/>
            </androidx.cardview.widget.CardView>

            <!-- Action Command Triggers -->
            <Button
                android:id="@+id/btnMarkCompleted"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Mark Activity as Resolved"
                android:backgroundTint="#1E7E34"
                android:fontFamily="sans-serif-medium"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnDetailBack"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Return to Dashboard Feed"
                android:backgroundTint="#F1F3F4"
                android:fontFamily="sans-serif-medium"
                android:textColor="#5F6368"
                android:textSize="15sp"
                android:layout_marginBottom="16dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>