<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Header Card Strip Layout with Built-In Navigation Back Control Arrow -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#311B92"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingVertical="24dp"
            android:gravity="center_vertical">

            <!-- System Minimalist Back Navigation Indicator Button Control -->
            <ImageButton
                android:id="@+id/btnBackReport"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="#FFFFFF"
                android:layout_marginEnd="12dp"
                android:contentDescription="Go Back"
                android:rotation="180" /> <!-- Flips icon to standard back arrow direction -->

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Submit Report Details"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Provide details to assist dashboard searches"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif"
                    android:textColor="#D1C4E9"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Form Elements Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Listing Category Type"
                android:fontFamily="sans-serif-medium"
                android:textSize="14sp"
                android:textColor="#202124"
                android:layout_marginBottom="8dp"/>

            <RadioGroup
                android:id="@+id/rgReportType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">
                <RadioButton
                    android:id="@+id/rbLost"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lost"
                    android:textColor="#202124"
                    android:fontFamily="sans-serif-medium"
                    android:checked="true"/>
                <RadioButton
                    android:id="@+id/rbFound"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Found"
                    android:textColor="#202124"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="24dp"/>
            </RadioGroup>

            <EditText
                android:id="@+id/etItemTitle"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Item Name (e.g., Matrix Card, Honda Keys)"
                android:inputType="text"
                android:paddingHorizontal="14dp"
                android:fontFamily="sans-serif"
                android:textSize="15sp"
                android:background="@drawable/bg_input_field"
                android:textColor="#202124"
                android:textColorHint="#757575"
                android:layout_marginBottom="16dp" />

            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Detailed description (Color traits, distinct markings)"
                android:inputType="textMultiLine"
                android:gravity="top"
                android:padding="14dp"
                android:lines="3"
                android:fontFamily="sans-serif"
                android:textSize="15sp"
                android:background="@drawable/bg_input_field"
                android:textColor="#202124"
                android:textColorHint="#757575"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Media Attachment"
                android:fontFamily="sans-serif-medium"
                android:textSize="14sp"
                android:textColor="#202124"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnSelectImage"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Attach Item Picture"
                android:backgroundTint="#5F6368"
                android:fontFamily="sans-serif-medium"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="140dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="20dp">
                <ImageView
                    android:id="@+id/ivReportPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#F1F3F4"
                    android:scaleType="centerInside"
                    android:src="@android:drawable/ic_menu_gallery"/>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:id="@+id/layoutMapSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap Map below to Pin Location"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="14sp"
                    android:textColor="#311B92"
                    android:layout_marginBottom="8dp"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <fragment
                        android:id="@+id/reportMap"
                        android:name="com.google.android.gms.maps.SupportMapFragment"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <EditText
                android:id="@+id/etContact"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="WhatsApp Phone Number (e.g., 0112345678)"
                android:inputType="phone"
                android:paddingHorizontal="14dp"
                android:fontFamily="sans-serif"
                android:textSize="15sp"
                android:background="@drawable/bg_input_field"
                android:textColor="#202124"
                android:textColorHint="#757575"
                android:layout_marginBottom="24dp" />

            <Button
                android:id="@+id/btnSubmitReport"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Publish to Activity Dashboard"
                android:background="@drawable/bg_primary_button"
                app:backgroundTint="@null"
                android:fontFamily="sans-serif-medium"
                android:textSize="16sp"
                android:textColor="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>